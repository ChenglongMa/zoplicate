{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "plansDirectory": "docs/ai/plans",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(tmux *)",
      "Bash(python3 ~/.claude/scripts/state_manager.py *)",
      "Bash(bash ~/.claude/scripts/run_tests.sh *)",
      "Bash(bash ~/.claude/scripts/watchdog.sh *)",
      "Bash(uv run python scripts/ci/check_stop.py)",
      "Bash(uv run python scripts/ci/check_zotero_upstream.py *)",
      "Bash(uv run python scripts/agent/update_zotero_reference.py *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(npm test *)",
      "Bash(npm run test *)",
      "Bash(npx jest *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npm run build *)",
      "WebSearch"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(docker *)"
    ],
    "deny": [
      "Bash(git reset *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git push --force *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'cd \"$CLAUDE_PROJECT_DIR\" && uv run python scripts/agent/update_zotero_reference.py --max-age-minutes 60'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'cd \"$CLAUDE_PROJECT_DIR\" && uv run python scripts/agent/update_zotero_reference.py --from-user-prompt --prompt-prefix /milestone-tdd --prompt-prefix /upstream-pr-milestone --max-age-minutes 60'"
          }
        ]
      }
    ]
  }
}
